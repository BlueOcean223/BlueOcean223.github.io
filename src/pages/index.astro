---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { SITE } from '../config';

const all = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

// Latest few, grouped by year for the feed column
const latest = all.slice(0, 6);
const groups: { year: number; items: typeof all }[] = [];
for (const post of latest) {
  const year = post.data.pubDate.getFullYear();
  let g = groups.find((x) => x.year === year);
  if (!g) {
    g = { year, items: [] };
    groups.push(g);
  }
  g.items.push(post);
}

const mmdd = (d: Date) =>
  `${String(d.getMonth() + 1).padStart(2, '0')}.${String(d.getDate()).padStart(2, '0')}`;

const socials = [
  { label: 'GitHub', href: 'https://github.com/BlueOcean223', icon: 'github' },
  { label: 'Email', href: 'mailto:blue2366108@163.com', icon: 'mail' },
  { label: 'RSS', href: '/rss.xml', icon: 'rss' },
];
---

<Base>
  <div class="container home">
    <!-- Profile -->
    <aside class="profile">
      <img
        class="avatar"
        src="/img/gongshuisanye.jpg"
        alt="头像"
        width="160"
        height="160"
        loading="eager"
        decoding="async"
      />
      <h1 class="name">blueOcean</h1>

      <nav class="socials" aria-label="社交链接">
        {socials.map((s) => (
          <a href={s.href} class="social" title={s.label} aria-label={s.label}>
            {s.icon === 'github' && (
              <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
                <path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.3.8-.6v-2c-3.2.7-3.9-1.4-3.9-1.4-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.1.1 1.7 1.2 1.7 1.2 1 1.7 2.7 1.2 3.3.9.1-.7.4-1.2.7-1.5-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17 4.8 18 5.1 18 5.1c.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.7 18.3.5 12 .5z"/>
              </svg>
            )}
            {s.icon === 'mail' && (
              <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <rect x="3" y="5" width="18" height="14" rx="2"/>
                <path d="m3 7 9 6 9-6"/>
              </svg>
            )}
            {s.icon === 'rss' && (
              <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
                <circle cx="5" cy="19" r="2"/>
                <path d="M4 11a9 9 0 0 1 9 9h-2.5A6.5 6.5 0 0 0 4 13.5V11z"/>
                <path d="M4 4a16 16 0 0 1 16 16h-2.5A13.5 13.5 0 0 0 4 6.5V4z"/>
              </svg>
            )}
          </a>
        ))}
      </nav>

      <p class="tagline">专注 AI 与 Agent</p>
      <p class="bio">
        你好，我是 blueOcean。目前专注于 AI 与 Agent 方向的学习与实践，
        也有后端开发的经验。这里记录我在探索过程中的笔记、思考与踩过的坑。
      </p>
    </aside>

    <!-- Latest Blogs -->
    <section class="feed">
      <h2 class="feed-title">Latest Blogs</h2>
      {groups.map((g) => (
        <div class="year-row">
          <div class="year-label">{g.year}</div>
          <ul class="year-items">
            {g.items.map((post) => (
              <li class="item">
                <span class="dot" aria-hidden="true"></span>
                <span class="date">{mmdd(post.data.pubDate)}</span>
                <a class="item-title" href={`/blog/${post.id}/`}>{post.data.title}</a>
              </li>
            ))}
          </ul>
        </div>
      ))}
      <a class="more" href="/blog/">查看全部文章 →</a>
    </section>
  </div>
</Base>

<style>
  .home {
    display: grid;
    grid-template-columns: minmax(260px, 340px) 1fr;
    gap: clamp(2rem, 6vw, 5rem);
    max-width: var(--wide-width);
    padding-top: 3.5rem;
    align-items: start;
  }

  /* ---- Profile ---- */
  .profile { text-align: center; }
  .avatar {
    width: 160px;
    height: 160px;
    border-radius: 50%;
    object-fit: cover;
    border: 4px solid var(--bg);
    box-shadow: 0 10px 30px rgba(80, 58, 45, 0.12);
    background: var(--bg-soft);
  }
  .name {
    font-family: var(--font-sans);
    font-size: 1.7rem;
    margin: 1rem 0 0.75rem;
  }
  .socials {
    display: flex;
    justify-content: center;
    gap: 18px;
    margin-bottom: 1rem;
  }
  .social {
    color: var(--muted);
    display: inline-flex;
    transition: color 0.15s ease, transform 0.15s ease;
  }
  .social:hover { color: var(--accent); transform: translateY(-2px); }

  .tagline {
    font-family: var(--font-sans);
    color: var(--text);
    font-size: 1rem;
    margin: 0 0 0.75rem;
  }
  .bio {
    color: var(--muted);
    font-size: 0.98rem;
    line-height: 1.7;
    margin: 0 auto;
    max-width: 30ch;
  }

  /* ---- Feed ---- */
  .feed-title {
    font-family: var(--font-sans);
    font-size: 2rem;
    margin: 0 0 1.75rem;
    letter-spacing: -0.01em;
  }
  .year-row {
    display: grid;
    grid-template-columns: 70px 1fr;
    gap: 1rem;
    margin-bottom: 0.5rem;
  }
  .year-label {
    font-family: var(--font-sans);
    font-size: 1.6rem;
    font-weight: 600;
    color: var(--border);
    line-height: 1.2;
    padding-top: 0.1rem;
  }
  .year-items {
    list-style: none;
    margin: 0;
    padding: 0 0 0 0.5rem;
    border-left: 1px solid var(--border);
  }
  .item {
    position: relative;
    display: flex;
    align-items: baseline;
    gap: 0.85rem;
    padding: 0.45rem 0 0.45rem 1.2rem;
  }
  .dot {
    position: absolute;
    left: -4.5px;
    top: 0.95rem;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--bg);
    border: 2px solid var(--accent);
  }
  .date {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: var(--muted);
    font-variant-numeric: tabular-nums;
    flex-shrink: 0;
  }
  .item-title {
    color: var(--text);
    font-size: 1.02rem;
  }
  .item-title:hover { color: var(--accent); text-decoration: none; }

  .more {
    display: inline-block;
    margin-top: 1.5rem;
    margin-left: 86px;
    font-family: var(--font-sans);
    font-size: 0.92rem;
    color: var(--muted);
  }
  .more:hover { color: var(--accent); }

  @media (max-width: 760px) {
    .home { grid-template-columns: 1fr; gap: 2.5rem; }
    .more { margin-left: 0; }
  }
</style>
